# 静的ファイル/PHPサイト向けvhost設定例(Apache+Nginxハイブリッド配信
# エンジン構想、`docroot`はホストにPHPビルトインサーバ(`php -S`)または
# 直接の静的ファイル配信で提供する)。
#
# 使い方:
#   OPEN_WEB_SERVER_WEB_VHOSTS_FILE=./web_vhosts.toml ./open-web-server
#
# 起動後も再起動不要で追加/削除できる:
#   curl -X POST http://localhost:8080/admin/web-vhosts \
#     -H 'content-type: application/json' \
#     -d '{"host":"audiocafe.tokyo","docroot":"F:/open-runo/audiocafe.tokyo","php_enabled":true}'
#   curl -X DELETE http://localhost:8080/admin/web-vhosts/audiocafe.tokyo
#   curl http://localhost:8080/admin/web-vhosts
#
# compat_mode (2026-07-24追加、open-easy-webの「初回セットアップガイド」
# 画面の「Apache互換モードで起動」/「Nginx互換モードで起動」ボタンに対応):
# php_enabled = false の静的サイトに限り、リクエストされたファイルが
# 見つからない場合の挙動を選べる。
#   "apache" -> .htaccessのFallbackResource相当、見つからなければ
#               index.htmlへフォールバック(SPA的挙動)。
#   "nginx"  -> try_files $uri $uri/ =404; 相当、フォールバックせず404
#               (既定値、省略時はこちら=既存動作と完全互換)。

# php_mode (2026-07-24追加、本番向けphp-fpm/FastCGI直結対応):
# php_enabled = true の場合の実際の配信方式を選べる。
#   省略時(既定) -> 開発用の`php -S`ビルトインサーバーをサブプロセス
#                    起動してリバースプロキシする従来方式。
#   [webvhost.php_mode]
#   mode = "fast_cgi"
#   fastcgi_addr = "127.0.0.1:9000"  # または "/run/php/php8.3-fpm.sock"
#     -> 既に稼働しているphp-fpmへFastCGI経由で直接接続する(サブプロセス
#        は起動しない)。この機能は`fastcgi-client` Cargo featureでのみ
#        有効(未有効ビルドでは501を返す、詳細はCLAUDE.md HANDOFF参照)。

[[webvhost]]
host = "audiocafe.tokyo"
docroot = "F:/open-runo/audiocafe.tokyo"
php_enabled = true
