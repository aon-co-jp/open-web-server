<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 常時電源接続プロファイル(2026-07-24新設)がPARTIAL_WAKE_LOCKで
         スリープを防ぐために必要。省電力/通常プロファイルでは取得しない
         (PowerProfile.kt参照)。 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_normal"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.OpenWebServer"
        android:usesCleartextTraffic="true">

        <!--
          起動時の電源プロファイル選択画面(2026-07-24新設)を実際の
          LAUNCHERにする。「文字表示」と「アイコン」の両方でプロファイルを
          区別できるようにする要件のうち、この画面自体が3プロファイルを
          絵文字+日本語ラベルで並べて選ばせる経路。
        -->
        <activity
            android:name=".ProfileSelectActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          open-web-server本体はKotlinコードではなくクロスコンパイル済みの
          ネイティブ実行ファイル(`libopenwebserver.so`、実体はELF実行
          ファイルをjniLibs命名規則に合わせてリネームしたもの——nativeLibraryDir
          配下はAndroid 10+のW^X制約下でも実行可能な数少ない領域のため、この
          「実行ファイルをlib*.soとして配置する」手法を採用している)を
          `MainActivity`が`ProcessBuilder`で起動する構成。フォアグラウンド
          サービス化は今回のスコープ外(CLAUDE.md参照)。`ProfileSelect
          Activity`または下記の`activity-alias`経由でのみ起動される
          (それ自身はLAUNCHERではない)。
        -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!--
          3電源プロファイルそれぞれの専用ホーム画面アイコン(2026-07-24
          新設)。「アイコン上にも省電力の文字を明示する」要件に対し、
          アイコン自体は色+シンボルで区別(緑=省電力/青=通常/橙=常時電源)、
          ラベル文字列(`app_name_powersave`等)にも明示的に文字で
          プロファイル名を含める。3つともホーム画面に並べてインストール
          でき、タップした瞬間にそのプロファイルで`MainActivity`が起動する
          (`ProfileSelectActivity`を経由しない近道)。
        -->
        <activity-alias
            android:name=".LauncherPowerSave"
            android:targetActivity=".MainActivity"
            android:icon="@drawable/ic_launcher_powersave"
            android:label="@string/app_name_powersave"
            android:exported="true">
            <intent-filter>
                <action android:name="tokyo.runo.openwebserver.LAUNCH_POWER_SAVE" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherNormal"
            android:targetActivity=".MainActivity"
            android:icon="@drawable/ic_launcher_normal"
            android:label="@string/app_name_normal"
            android:exported="true">
            <intent-filter>
                <action android:name="tokyo.runo.openwebserver.LAUNCH_NORMAL" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherAlwaysOn"
            android:targetActivity=".MainActivity"
            android:icon="@drawable/ic_launcher_alwayson"
            android:label="@string/app_name_alwayson"
            android:exported="true">
            <intent-filter>
                <action android:name="tokyo.runo.openwebserver.LAUNCH_ALWAYS_ON" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>
