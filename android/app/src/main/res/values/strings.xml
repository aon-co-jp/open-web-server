<resources>
    <string name="app_name">open-web-server</string>
    <string name="app_name_memorysaver">open-web-server (省メモリ)</string>
    <string name="app_name_powersave">open-web-server (省電力)</string>
    <string name="app_name_normal">open-web-server (通常)</string>
    <string name="app_name_alwayson">open-web-server (常時電源)</string>

    <string name="profile_select_title">電源プロファイルを選択</string>
    <string name="profile_select_subtitle">端末の使い方に合わせて選んでください。あとで「プロファイル変更」からいつでも選び直せます。</string>

    <string name="profile_memory_saver_button">🧠 省メモリ モード</string>
    <string name="profile_memory_saver_desc">メモリの少ない端末向け。画像/データキャッシュやログ保持量を厳しく減らし、バックグラウンドでの先読みも行いません(省電力=ポーリング間隔延長とは別軸の最適化です)。</string>

    <string name="profile_power_save_button">🔋 省電力 モード</string>
    <string name="profile_power_save_desc">スマホとして普段使いする端末向け。バックグラウンドでの常時稼働を避け、Android標準の省電力(Doze)機能に逆らいません。</string>

    <string name="profile_normal_button">⚖️ 通常 モード</string>
    <string name="profile_normal_desc">通常のスマホ利用とサーバー稼働を両立するバランス型(既定)。</string>

    <string name="profile_always_on_button">🔌 常時電源接続 モード</string>
    <string name="profile_always_on_desc">充電しっぱなしのサーバー専用端末向け。WakeLockでスリープを防ぎ、常時稼働を優先します。</string>

    <string name="open_easy_web_button">🌐 open-easy-web ウィザードを開く</string>
    <string name="change_profile_button">電源プロファイルを変更</string>
    <string name="ddns_setup_button">🌍 DuckDNSドメイン設定</string>

    <string name="ddns_setup_title">DuckDNS ドメイン設定</string>
    <string name="ddns_setup_explainer">duckdns.org で取得したサブドメイン名とトークンを登録すると、起動中のopen-web-serverが5分間隔で自動的にIPを更新します(最大20ドメインまで)。トークン自体はduckdns.orgへのログインで取得してください(このアプリは代行取得しません)。</string>
    <string name="ddns_admin_token_hint">管理APIトークン(サーバー起動時と共通の値)</string>
    <string name="ddns_subdomain_hint">サブドメイン名(例: myhost)</string>
    <string name="ddns_token_hint">DuckDNSトークン</string>
    <string name="ddns_register_button">登録する</string>
    <string name="ddns_registered_list_title">登録済みドメイン</string>
</resources>
